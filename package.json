{
  "name": "bright-news",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "assets:generate": "npx @capacitor/assets generate --assetPath resources --iconBackgroundColor '#7c3aed' --iconBackgroundColorDark '#0f172a' --splashBackgroundColor '#7c3aed' --splashBackgroundColorDark '#0f172a' --logoSplashScale 0.22 --pwaNoAppleFetch true && mkdir -p public/icons && mv -f icons/* public/icons/ && rmdir icons",
    "mobile:build": "npm run build && npx cap sync",
    "android:bundle:release": "cd android && ./gradlew bundleRelease",
    "android:apk:release": "cd android && ./gradlew assembleRelease",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "lint": "eslint .",
    "preview": "vite preview",
    "ingest:gnews": "node --env-file=.env scripts/ingest-gnews.mjs",
    "ingest:gdelt": "node --env-file=.env scripts/ingest-gdelt.mjs",
    "ingest:google-news-rss": "node --env-file=.env scripts/ingest-google-news-rss.mjs",
    "ingest:newscatcher": "node --env-file=.env scripts/ingest-newscatcher.mjs",
    "ingest:rss": "node --env-file=.env scripts/ingest-rss.mjs",
    "review:pending": "node --env-file=.env scripts/review-pending-with-openai.mjs",
    "publish:approved": "node --env-file=.env scripts/publish-approved-stories.mjs",
    "backfill:source-urls": "node --env-file=.env scripts/backfill-source-urls.mjs",
    "refresh:news": "node --env-file=.env scripts/refresh-news.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@supabase/supabase-js": "^2.100.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@capacitor/assets": "^3.0.5",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "sass": "^1.98.0",
    "vite": "^8.0.1"
  }
}
